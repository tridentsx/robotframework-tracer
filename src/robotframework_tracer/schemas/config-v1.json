{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/tridentsx/robotframework-tracer/schemas/config-v1.json",
  "title": "Robot Framework Tracer Configuration",
  "description": "Schema for .rf-tracer.json configuration files (v1.x)",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^1\\.\\d+\\.\\d+$",
      "description": "Schema version (must be 1.x.x)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of this configuration"
    },
    "endpoint": {
      "type": "string",
      "description": "OTLP endpoint URL (default: http://localhost:4318/v1/traces)"
    },
    "endpoints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of OTLP endpoint URLs to send traces to (config file only)"
    },
    "service_name": {
      "type": "string",
      "description": "Service name in traces (default: rf)"
    },
    "protocol": {
      "type": "string",
      "enum": ["http", "grpc"],
      "description": "Export protocol (default: http)"
    },
    "sample_rate": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Sampling rate 0.0-1.0 (default: 1.0)"
    },
    "span_prefix_style": {
      "type": "string",
      "enum": ["none", "text", "emoji"],
      "description": "Span name prefix style (default: none)"
    },
    "capture_arguments": {
      "type": "boolean",
      "description": "Capture keyword arguments (default: true)"
    },
    "max_arg_length": {
      "type": "integer",
      "minimum": 0,
      "description": "Max length for keyword arguments (default: 200)"
    },
    "capture_logs": {
      "type": "boolean",
      "description": "Capture log messages via Logs API (default: false)"
    },
    "log_level": {
      "type": "string",
      "enum": ["TRACE", "DEBUG", "INFO", "WARN", "ERROR"],
      "description": "Minimum log level to capture (default: INFO)"
    },
    "max_log_length": {
      "type": "integer",
      "minimum": 0,
      "description": "Max length for log messages (default: 500)"
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "description": "Trace output file settings",
      "properties": {
        "file": {
          "type": "string",
          "description": "Output file path or 'auto' for auto-naming"
        },
        "format": {
          "type": "string",
          "enum": ["json", "gz"],
          "description": "Output format (default: json)"
        },
        "filter": {
          "type": "string",
          "description": "Output filter preset (minimal, full) or path to filter .json"
        }
      }
    }
  }
}
